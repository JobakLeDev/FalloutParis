# ===== Discord =====
DISCORD_TOKEN=          # Token du bot (Discord Developer Portal > Bot)
DISCORD_CLIENT_ID=      # Application ID (General Information)
DISCORD_GUILD_ID=       # ID du serveur (clic droit serveur > Copier l'identifiant)

# Salons (clic droit salon > Copier l'identifiant — mode développeur activé)
FICHES_CHANNEL_ID=      # #fiches-live  (notifications de changement de fiche)
ARCHIVES_CHANNEL_ID=    # #archives-sessions
SESSION_CHANNEL_ID=     # #session-en-cours (par défaut pour /archive-session)

# ===== Firebase (Admin SDK, lecture Firestore) =====
FIREBASE_PROJECT_ID=fallout-paris
# Une des deux options pour la clé de service :
#  A) chemin vers le fichier JSON de compte de service
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
#  B) ou le JSON complet en une seule variable (utile en hébergement)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
